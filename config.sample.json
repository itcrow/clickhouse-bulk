{
  "listen": ":8124",
  "flush_count": 10000,
  "flush_interval": 1000,
  "clean_interval": 0,
  "remove_query_id": true,
  "max_request_bytes": 134217728,
  "dump_check_interval": 300,
  "bkp_dump_check_interval": 0,
  "dump_replay_batch": 10,
  "max_dump_files": 0,
  "debug": false,
  "log_queries": true,
  "dump_dir": "dumps",
  "journal_dir": "journal",
  "journal_fsync": false,
  "max_journal_pending": 1000000,
  "shutdown_drain_sec": 60,
  "clickhouse": {
    "down_timeout": 60,
    "connect_timeout": 10,
    "tls_server_name": "",
    "insecure_tls_skip_verify": false,
    "send_max_rps": 0,
    "send_max_burst": 0,
    "servers": [
      "http://127.0.0.1:8123"
    ]
  },
  "use_tls": false,
  "tls_cert_file": "",
  "tls_key_file": ""
}
